<Window x:Class="C_toolsDddPlugin.DddPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:C_toolsDddPlugin"
        xmlns:shared="clr-namespace:C_toolsShared;assembly=C_toolsShared"
        Title="C_TOOL 文字标注"
        Width="600"
        Height="1080"
        MinWidth="600"
        MinHeight="1080"
        MaxWidth="600"
        MaxHeight="1080"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False"
        Background="#262C38"
        Foreground="#E8EAED"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="12"
        Loaded="Window_Loaded"
        Activated="DddPanelWindow_Activated">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/C_toolsShared;component/Themes/CadTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <shared:DataGridRowIndexConverter x:Key="RowIndexConverter" />

      <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
      <Setter Property="Foreground" Value="#E6E8EA" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="8,16" />
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="DataGridColumnHeader">
            <Border x:Name="HeaderBorder"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Background="{StaticResource Cad.GridHeaderBg}">
              <ContentPresenter Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                SnapsToDevicePixels="True" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DgHeaderFirstColumn" TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeader}">
      <Setter Property="Padding" Value="8,16" />
    </Style>

    <Style x:Key="DgHeaderIndexColumn" TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeader}">
      <Setter Property="Padding" Value="4,16" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style x:Key="DgHeaderSpacerColumn" TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeader}">
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="CadDataGridCell" TargetType="DataGridCell">
      <Setter Property="Foreground" Value="#E6E8EA" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FontSize" Value="13" />
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Foreground" Value="#E6E8EA" />
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{StaticResource Cad.GridRowHover}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CadDataGridCellIndexColumn" TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCell}">
      <Setter Property="Padding" Value="4,0,4,0" />
      <Setter Property="Foreground" Value="Transparent" />
    </Style>
    <Style x:Key="CadDataGridCellSpacerColumn" TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCell}">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="Transparent" />
    </Style>

    <Style TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCell}" />
    <Style x:Key="CadDataGridCellFirstColumn" TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCell}">
      <Setter Property="Padding" Value="8,0,8,0" />
    </Style>

    <Style x:Key="CadDgCellTextBlock" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style x:Key="CadDgCellTextBox" TargetType="TextBox">
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- DDD 工具栏输入：与 PrimaryButton 同高 32px -->
    <Style x:Key="DddToolbarInputTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
      <Setter Property="Height" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="MaxHeight" Value="32" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Key="DddToolbarMultilineInputTextBox" TargetType="TextBox" BasedOn="{StaticResource DddToolbarInputTextBox}">
      <Setter Property="Height" Value="72" />
      <Setter Property="MinHeight" Value="72" />
      <Setter Property="MaxHeight" Value="120" />
      <Setter Property="AcceptsReturn" Value="True" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="VerticalContentAlignment" Value="Top" />
      <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
      <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style x:Key="DddPrimaryButton" TargetType="Button">
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Background" Value="{StaticResource Cad.ButtonPrimary}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="20,0" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="MinWidth" Value="112" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#2386CC" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#1664A8" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#6D7682" />
                <Setter TargetName="Bd" Property="Opacity" Value="0.65" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="DddSecondaryButton" TargetType="Button">
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Background" Value="#2D333B" />
      <Setter Property="Foreground" Value="#E6E8EA" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="20,0" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="MinWidth" Value="112" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#363D47" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#1E2630" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#6D7682" />
                <Setter TargetName="Bd" Property="Opacity" Value="0.65" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 列表单元格：正文与行高匹配、垂直居中 -->
    <Style x:Key="DddGridCellTextBlock" TargetType="TextBlock" BasedOn="{StaticResource CadDgCellTextBlock}">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Key="CadCheckBox" TargetType="CheckBox">
      <Setter Property="Width" Value="22" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
              <Border x:Name="Box"
                      Width="18"
                      Height="18"
                      Background="#1F2535"
                      BorderBrush="#6C789A"
                      BorderThickness="1.2"
                      CornerRadius="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
              <Path x:Name="CheckMark"
                    Data="M 4 9 L 7.5 12.5 L 14 6"
                    Stroke="White"
                    StrokeThickness="2"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Stretch="Fill"
                    Width="10"
                    Height="8"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Cad.Accent}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Box" Property="Background" Value="{StaticResource Cad.Accent}" />
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Cad.Accent}" />
                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Box" Property="Opacity" Value="0.4" />
                <Setter TargetName="CheckMark" Property="Opacity" Value="0.4" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="DddGridCellMultilineTextBlock" TargetType="TextBlock" BasedOn="{StaticResource DddGridCellTextBlock}">
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="TextTrimming" Value="None" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Key="DddGridCellTextBoxEdit" TargetType="TextBox" BasedOn="{StaticResource CadDgCellTextBox}">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="MinHeight" Value="28" />
    </Style>
    <Style x:Key="DddGridCellMultilineTextBoxEdit" TargetType="TextBox" BasedOn="{StaticResource DddGridCellTextBoxEdit}">
      <Setter Property="AcceptsReturn" Value="True" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="VerticalContentAlignment" Value="Top" />
      <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="MinHeight" Value="56" />
    </Style>
    <Style x:Key="DddFooterIconButton" TargetType="Button" BasedOn="{StaticResource CadToolbarIconButton}">
      <Setter Property="Width" Value="34" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
    </Style>
    <Style x:Key="DddFooterIconToggleButton" TargetType="ToggleButton">
      <Setter Property="Width" Value="34" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource Cad.Muted}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="UseLayoutRounding" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="Bd"
                    Background="Transparent"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#313750" />
                <Setter Property="Foreground" Value="#FFFFFF" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#313750" />
                <Setter Property="Foreground" Value="#FFFFFF" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#202538" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="CadDataGridCellDdd" TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCell}">
      <Setter Property="Padding" Value="8,2" />
    </Style>
    <Style x:Key="CadDataGridCellFirstColumnDdd" TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCellFirstColumn}">
      <Setter Property="Padding" Value="8,2,8,2" />
    </Style>
    <Style x:Key="CadDataGridCellIndexColumnDdd" TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCellIndexColumn}">
      <Setter Property="Padding" Value="0,2,4,2" />
    </Style>
    <Style x:Key="CadDataGridCellActionColumnDdd" TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCell}">
      <Setter Property="Padding" Value="4,2,4,2" />
    </Style>

    <Style x:Key="CadDataGrid" TargetType="DataGrid">
      <Style.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E6E8EA" />
        <Style TargetType="ScrollBar">
          <Setter Property="Width" Value="0" />
          <Setter Property="Height" Value="0" />
          <Setter Property="Opacity" Value="0" />
          <Setter Property="IsHitTestVisible" Value="False" />
          <Setter Property="Focusable" Value="False" />
        </Style>
      </Style.Resources>
      <Setter Property="RowHeight" Value="{x:Static sys:Double.NaN}" />
      <Setter Property="Background" Value="{StaticResource Cad.GridBg}" />
      <Setter Property="Foreground" Value="#E6E8EA" />
      <Setter Property="BorderBrush" Value="{StaticResource Cad.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Cad.GridLine}" />
      <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
      <Setter Property="RowBackground" Value="{StaticResource Cad.GridRow}" />
      <Setter Property="AlternatingRowBackground" Value="{StaticResource Cad.GridRowAlt}" />
      <Setter Property="ColumnHeaderStyle" Value="{StaticResource DgHeader}" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="RowHeaderWidth" Value="0" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="EnableRowVirtualization" Value="True" />
      <Setter Property="EnableColumnVirtualization" Value="True" />
      <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
      <Setter Property="ScrollViewer.PanningMode" Value="Both" />
      <Setter Property="Padding" Value="0" />
      <!-- DataGrid 模板：直角列表，无圆角；内容区由前后空白列提供缓冲 -->
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="DataGrid">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="0"
                    SnapsToDevicePixels="True">
              <ScrollViewer x:Name="DG_ScrollViewer"
                              Focusable="False"
                              CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                              PanningMode="{TemplateBinding ScrollViewer.PanningMode}">
                <ScrollViewer.Template>
                  <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <Button Grid.Row="0"
                              Grid.Column="0"
                              Command="{x:Static DataGrid.SelectAllCommand}"
                              Width="{Binding CellsPanelHorizontalOffset, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                              Focusable="False"
                              Style="{DynamicResource {ComponentResourceKey TypeInTargetAssembly={x:Type DataGrid}, ResourceId=DataGridSelectAllButtonStyle}}"
                              Visibility="{Binding HeadersVisibility, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, ConverterParameter={x:Static DataGridHeadersVisibility.All}}" />
                      <DataGridColumnHeadersPresenter x:Name="PART_ColumnHeadersPresenter"
                                                      Grid.Row="0"
                                                      Grid.Column="1"
                                                      Visibility="{Binding HeadersVisibility, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, ConverterParameter={x:Static DataGridHeadersVisibility.Column}}" />
                      <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                              Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              CanContentScroll="{TemplateBinding CanContentScroll}" />
                      <ScrollBar x:Name="PART_VerticalScrollBar"
                                 Grid.Row="1"
                                 Grid.Column="2"
                                 Orientation="Vertical"
                                 Maximum="{TemplateBinding ScrollableHeight}"
                                 ViewportSize="{TemplateBinding ViewportHeight}"
                                 Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                 Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                      <Grid Grid.Row="2"
                            Grid.Column="1">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="{Binding NonFrozenColumnsViewportHorizontalOffset, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Column="1"
                                   Orientation="Horizontal"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Value="{Binding HorizontalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
                      </Grid>
                    </Grid>
                  </ControlTemplate>
                </ScrollViewer.Template>
                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
              </ScrollViewer>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TabItem" BasedOn="{StaticResource CadHeaderTabItem}" />

    <Style TargetType="TabControl" BasedOn="{StaticResource CadContentTabs}" />

    <Style x:Key="DddTabControl" TargetType="TabControl" BasedOn="{StaticResource CadContentTabs}" />

    <Style x:Key="CadToggleSwitch" TargetType="CheckBox">
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Grid Width="42" Height="22" SnapsToDevicePixels="True">
              <Border x:Name="Track"
                      CornerRadius="11"
                      BorderThickness="1"
                      BorderBrush="{StaticResource Cad.Border}"
                      Background="#353B44" />
              <Ellipse x:Name="Thumb"
                       Width="16"
                       Height="16"
                       HorizontalAlignment="Left"
                       Margin="3,0,0,0"
                       Fill="#E8EAED" />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Track" Property="Background" Value="{StaticResource Cad.Accent}" />
                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource Cad.Accent}" />
                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                <Setter TargetName="Thumb" Property="Fill" Value="White" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource Cad.Accent}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Track" Property="Opacity" Value="0.45" />
                <Setter TargetName="Thumb" Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    </ResourceDictionary>
  </Window.Resources>
  <Border Background="{StaticResource Cad.Panel}"
          BorderBrush="{StaticResource Cad.Border}"
          BorderThickness="0"
          CornerRadius="0"
          SnapsToDevicePixels="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Border Grid.Row="0"
              Background="{StaticResource Cad.ToolbarBg}"
              BorderBrush="{StaticResource Cad.Border}"
              BorderThickness="0,0,0,1"
              Padding="12,10">
        <Grid x:Name="InputPanel" VerticalAlignment="Top">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock x:Name="TxtAddLabel"
                     Grid.Row="0"
                     Grid.Column="0"
                     Text="文字"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0"
                     FontSize="12"
                     Foreground="{StaticResource Cad.Muted}" />
          <TextBox x:Name="TxtAddText"
                   Grid.Row="0"
                   Grid.Column="1"
                   HorizontalAlignment="Stretch"
                   Style="{StaticResource DddToolbarMultilineInputTextBox}"
                   ToolTip="{x:Static local:DddPanelUiStrings.ToolTipTxtAdd}" />
          <Grid Grid.Row="0"
                Grid.Column="2"
                Margin="10,0,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Button Grid.Row="0"
                    Content="插入"
                    Width="96"
                    Height="32"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Style="{StaticResource DddPrimaryButton}"
                    ToolTip="{x:Static local:DddPanelUiStrings.ToolTipInsertFromInputButton}"
                    Click="InsertFromInput_Click" />
            <Button Grid.Row="1"
                    Margin="0,8,0,0"
                    Content="选择"
                    Width="96"
                    Height="32"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Style="{StaticResource DddSecondaryButton}"
                    ToolTip="{x:Static local:DddPanelUiStrings.ToolTipPickTextButton}"
                    Click="PickTextFromCad_Click" />
          </Grid>
          <TextBlock Grid.Row="1"
                     Grid.Column="0"
                     Text="引线样式"
                     Margin="0,10,12,0"
                     VerticalAlignment="Center"
                     FontSize="12"
                     Foreground="{StaticResource Cad.Muted}" />
          <Border Grid.Row="1"
                  Grid.Column="1"
                  Background="{StaticResource Cad.InputBg}"
                  BorderBrush="{StaticResource Cad.Border}"
                  BorderThickness="1"
                  CornerRadius="4"
                  Height="32"
                  Margin="0,10,0,0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center">
            <ComboBox x:Name="CmbMLeaderStyle"
                      Style="{StaticResource CadToolbarComboBox}"
                      VerticalAlignment="Stretch"
                      VerticalContentAlignment="Center"
                      SelectionChanged="CmbMLeaderStyle_SelectionChanged"
                      ToolTip="{x:Static local:DddPanelUiStrings.ToolTipMLeaderStyleCombo}" />
          </Border>
          <Button Grid.Row="1"
                  Grid.Column="2"
                  Margin="10,10,0,0"
                  Content="设置引线"
                  Width="112"
                  HorizontalAlignment="Right"
                  Style="{StaticResource DddSecondaryButton}"
                  ToolTip="{x:Static local:DddPanelUiStrings.ToolTipSetLeaderButton}"
                  Click="OpenMLeaderStyleDialog_Click" />
        </Grid>
      </Border>
      <Grid Grid.Row="1">
        <TabControl x:Name="MainTabs"
                    Style="{StaticResource DddTabControl}"
                    Background="{StaticResource Cad.RowAlt}"
                    BorderThickness="0"
                    SelectionChanged="MainTabs_SelectionChanged">
          <TabItem Header="文字列表">
          <DataGrid x:Name="GridRemarks"
                      Style="{StaticResource CadDataGrid}"
                      BorderThickness="0"
                      MinRowHeight="36"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      KeyDown="ListGrid_KeyDown"
                      PreviewMouseLeftButtonDown="GridRemarks_PreviewMouseLeftButtonDown">
              <DataGrid.Columns>
                <DataGridTemplateColumn Width="48" MinWidth="48" CanUserResize="False" HeaderStyle="{StaticResource DgHeaderIndexColumn}" CellStyle="{StaticResource CadDataGridCellActionColumnDdd}">
                  <DataGridTemplateColumn.Header>
                    <TextBlock Text="选择" HorizontalAlignment="Center" />
                  </DataGridTemplateColumn.Header>
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <CheckBox HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource CadCheckBox}"
                                IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="文字内容" Width="*"
                                    Binding="{Binding RemarkText, UpdateSourceTrigger=PropertyChanged}"
                                    HeaderStyle="{StaticResource DgHeaderFirstColumn}"
                                    CellStyle="{StaticResource CadDataGridCellFirstColumnDdd}"
                                    ElementStyle="{StaticResource DddGridCellMultilineTextBlock}"
                                    EditingElementStyle="{StaticResource DddGridCellMultilineTextBoxEdit}" />
                <DataGridTemplateColumn Width="18"
                                        MinWidth="18"
                                        CanUserResize="False"
                                        CanUserSort="False"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource DgHeaderSpacerColumn}"
                                        CellStyle="{StaticResource CadDataGridCellSpacerColumn}">
                  <DataGridTemplateColumn.Header>
                    <TextBlock Text=""
                               Foreground="Transparent" />
                  </DataGridTemplateColumn.Header>
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Border Background="Transparent" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="道具列表">
          <DataGrid x:Name="GridProps"
                    Style="{StaticResource CadDataGrid}"
                    BorderThickness="0"
                    MinRowHeight="36"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="True"
                    SelectionMode="Extended"
                    SelectionUnit="FullRow"
                    KeyDown="ListGrid_KeyDown"
                    PreviewMouseLeftButtonDown="GridProps_PreviewMouseLeftButtonDown">
            <DataGrid.Columns>
              <DataGridTemplateColumn Width="48" MinWidth="48" CanUserResize="False" HeaderStyle="{StaticResource DgHeaderIndexColumn}" CellStyle="{StaticResource CadDataGridCellActionColumnDdd}">
                <DataGridTemplateColumn.Header>
                  <TextBlock Text="选择" HorizontalAlignment="Center" />
                </DataGridTemplateColumn.Header>
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <CheckBox HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Style="{StaticResource CadCheckBox}"
                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="道具名称" Width="1.2*"
                                  Binding="{Binding ItemName, UpdateSourceTrigger=PropertyChanged}"
                                  HeaderStyle="{StaticResource DgHeader}"
                                  CellStyle="{StaticResource CadDataGridCellDdd}"
                                  ElementStyle="{StaticResource DddGridCellTextBlock}"
                                  EditingElementStyle="{StaticResource DddGridCellTextBoxEdit}" />
              <DataGridTextColumn Header="价格" Width="1*"
                                  Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged}"
                                  HeaderStyle="{StaticResource DgHeader}"
                                  CellStyle="{StaticResource CadDataGridCellDdd}"
                                  ElementStyle="{StaticResource DddGridCellTextBlock}"
                                  EditingElementStyle="{StaticResource DddGridCellTextBoxEdit}" />
              <DataGridTextColumn Header="备注" Width="1*"
                                  Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                  HeaderStyle="{StaticResource DgHeader}"
                                  CellStyle="{StaticResource CadDataGridCellDdd}"
                                  ElementStyle="{StaticResource DddGridCellTextBlock}"
                                  EditingElementStyle="{StaticResource DddGridCellTextBoxEdit}" />
              <DataGridTemplateColumn Width="18"
                                      MinWidth="18"
                                      CanUserResize="False"
                                      CanUserSort="False"
                                      IsReadOnly="True"
                                      HeaderStyle="{StaticResource DgHeaderSpacerColumn}"
                                      CellStyle="{StaticResource CadDataGridCellSpacerColumn}">
                <DataGridTemplateColumn.Header>
                  <TextBlock Text=""
                             Foreground="Transparent" />
                </DataGridTemplateColumn.Header>
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Border Background="Transparent" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
          </TabItem>
          <TabItem Header="材料列表">
          <DataGrid x:Name="GridMaterials"
                      Style="{StaticResource CadDataGrid}"
                      BorderThickness="0"
                      MinRowHeight="36"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      KeyDown="ListGrid_KeyDown"
                      PreviewMouseLeftButtonDown="GridMaterials_PreviewMouseLeftButtonDown">
              <DataGrid.Columns>
                <DataGridTemplateColumn Width="48" MinWidth="48" CanUserResize="False" HeaderStyle="{StaticResource DgHeaderIndexColumn}" CellStyle="{StaticResource CadDataGridCellActionColumnDdd}">
                  <DataGridTemplateColumn.Header>
                    <TextBlock Text="选择" HorizontalAlignment="Center" />
                  </DataGridTemplateColumn.Header>
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <CheckBox HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource CadCheckBox}"
                                IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="材料名称" Width="1.2*"
                                    Binding="{Binding MaterialName, UpdateSourceTrigger=PropertyChanged}"
                                    HeaderStyle="{StaticResource DgHeader}"
                                    CellStyle="{StaticResource CadDataGridCellDdd}"
                                    ElementStyle="{StaticResource DddGridCellTextBlock}"
                                    EditingElementStyle="{StaticResource DddGridCellTextBoxEdit}" />
                <DataGridTextColumn Header="规格" Width="1*"
                                    Binding="{Binding Specification, UpdateSourceTrigger=PropertyChanged}"
                                    HeaderStyle="{StaticResource DgHeader}"
                                    CellStyle="{StaticResource CadDataGridCellDdd}"
                                    ElementStyle="{StaticResource DddGridCellTextBlock}"
                                    EditingElementStyle="{StaticResource DddGridCellTextBoxEdit}" />
                <DataGridTextColumn Header="备注" Width="1*"
                                    Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                    HeaderStyle="{StaticResource DgHeader}"
                                    CellStyle="{StaticResource CadDataGridCellDdd}"
                                    ElementStyle="{StaticResource DddGridCellTextBlock}"
                                    EditingElementStyle="{StaticResource DddGridCellTextBoxEdit}" />
                <DataGridTemplateColumn Width="18"
                                        MinWidth="18"
                                        CanUserResize="False"
                                        CanUserSort="False"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource DgHeaderSpacerColumn}"
                                        CellStyle="{StaticResource CadDataGridCellSpacerColumn}">
                  <DataGridTemplateColumn.Header>
                    <TextBlock Text=""
                               Foreground="Transparent" />
                  </DataGridTemplateColumn.Header>
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Border Background="Transparent" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
        </TabControl>
        <StackPanel Panel.ZIndex="2"
                    Orientation="Horizontal"
                    Height="32"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,12,0"
                    ToolTip="{x:Static local:DddPanelUiStrings.ToolTipInsertWithLeaderToggle}">
          <TextBlock Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     FontSize="12"
                     Foreground="{StaticResource Cad.Muted}"
                     Text="带引线" />
          <CheckBox x:Name="ChkInsertWithLeader"
                    IsChecked="True"
                    Style="{StaticResource CadToggleSwitch}"
                    Checked="InsertWithLeaderMode_Changed"
                    Unchecked="InsertWithLeaderMode_Changed" />
        </StackPanel>
      </Grid>
      <Border Grid.Row="2"
              Background="{StaticResource Cad.RowAlt}"
              BorderBrush="{StaticResource Cad.StatusLine}"
              BorderThickness="0,1,0,0"
              Padding="8,4">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock x:Name="StatusText"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     FontSize="12"
                     Foreground="{StaticResource Cad.Muted}"
                     TextWrapping="Wrap" />
          <Button x:Name="BtnImportTableFromXlsx"
                  Grid.Column="1"
                  Style="{StaticResource DddFooterIconButton}"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center"
                  ToolTip="{x:Static local:DddPanelUiStrings.ToolTipImportTable}"
                  Click="ImportTableFromXlsx_Click">
            <ContentControl Style="{StaticResource CadImportIconControl}"
                            Width="16"
                            Height="16"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground, FallbackValue={StaticResource Cad.Muted}, TargetNullValue={StaticResource Cad.Muted}}" />
          </Button>
          <ToggleButton x:Name="BtnSelectionMode"
                  Grid.Column="2"
                  Style="{StaticResource DddFooterIconToggleButton}"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center"
                  ToolTip="{x:Static local:DddPanelUiStrings.ToolTipSelectionMode}"
                  Checked="SelectionMode_Changed"
                  Unchecked="SelectionMode_Changed">
            <ContentControl Style="{StaticResource CadRectSelectIconControl}"
                            Width="16"
                            Height="16"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground, FallbackValue={StaticResource Cad.Muted}, TargetNullValue={StaticResource Cad.Muted}}" />
          </ToggleButton>
          <Button x:Name="BtnDeleteSelectedRows"
                  Grid.Column="3"
                  Style="{StaticResource DddFooterIconButton}"
                  VerticalAlignment="Center"
                  ToolTip="{x:Static local:DddPanelUiStrings.ToolTipDeleteSelectedRows}"
                  Click="DeleteSelectedRows_Click">
            <ContentControl Style="{StaticResource CadTrashIconControl}"
                            Width="16"
                            Height="16"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground, FallbackValue={StaticResource Cad.Muted}, TargetNullValue={StaticResource Cad.Muted}}" />
          </Button>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
