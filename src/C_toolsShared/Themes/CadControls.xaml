<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">
  <!-- 共享控件模板在独立 WPF 宿主里会直接解析本字典内的 StaticResource，
       这里重复声明 Cad 基础色键，避免依赖兄弟 merged dictionary 的运行时查找。 -->
  <SolidColorBrush x:Key="Cad.Panel" Color="#262C38" />
  <SolidColorBrush x:Key="Cad.Border" Color="#21262D" />
  <SolidColorBrush x:Key="Cad.Muted" Color="#8B949E" />
  <SolidColorBrush x:Key="Cad.Accent" Color="#58A6FF" />
  <SolidColorBrush x:Key="Cad.RowAlt" Color="#262C38" />
  <SolidColorBrush x:Key="Cad.HeaderBg" Color="#262C38" />
  <SolidColorBrush x:Key="Cad.InputBg" Color="#262C38" />
  <SolidColorBrush x:Key="Cad.GridBg" Color="#16191F" />
  <SolidColorBrush x:Key="Cad.GridHeaderBg" Color="#1B1F28" />
  <SolidColorBrush x:Key="Cad.GridRow" Color="#12141A" />
  <SolidColorBrush x:Key="Cad.GridRowAlt" Color="#12141A" />
  <SolidColorBrush x:Key="Cad.GridLine" Color="#252B36" />
  <SolidColorBrush x:Key="Cad.GridRowHover" Color="#222731" />
  <SolidColorBrush x:Key="Cad.ScrollTrack" Color="#10151C" />
  <SolidColorBrush x:Key="Cad.ScrollThumb" Color="#3D4756" />
  <SolidColorBrush x:Key="Cad.ScrollThumbHover" Color="#4E5A6A" />
  <SolidColorBrush x:Key="Cad.ButtonPrimary" Color="#1E77B4" />
  <SolidColorBrush x:Key="Cad.ToolbarBg" Color="#323B4A" />
  <SolidColorBrush x:Key="Cad.StatusLine" Color="#30363D" />
  <SolidColorBrush x:Key="Cad.TabIdle" Color="#262C38" />
  <SolidColorBrush x:Key="Cad.TabHover" Color="#2C3340" />
  <SolidColorBrush x:Key="Cad.TabSelected" Color="#262C38" />

  <ControlTemplate x:Key="CadScrollBarVertical" TargetType="ScrollBar">
    <Grid x:Name="Bg"
          Width="{TemplateBinding Width}"
          Background="Transparent"
          SnapsToDevicePixels="True">
      <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
        <Track.DecreaseRepeatButton>
          <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False" IsTabStop="False" Opacity="0" />
        </Track.DecreaseRepeatButton>
        <Track.IncreaseRepeatButton>
          <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False" IsTabStop="False" Opacity="0" />
        </Track.IncreaseRepeatButton>
        <Track.Thumb>
          <Thumb>
            <Thumb.Template>
              <ControlTemplate TargetType="Thumb">
                <Border x:Name="T"
                        Background="{StaticResource Cad.ScrollThumb}"
                        CornerRadius="4"
                        Margin="1,3"
                        SnapsToDevicePixels="True" />
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="T" Property="Background" Value="{StaticResource Cad.ScrollThumbHover}" />
                  </Trigger>
                  <Trigger Property="IsDragging" Value="True">
                    <Setter TargetName="T" Property="Background" Value="{StaticResource Cad.Accent}" />
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Thumb.Template>
          </Thumb>
        </Track.Thumb>
      </Track>
    </Grid>
  </ControlTemplate>

  <ControlTemplate x:Key="CadScrollBarHorizontal" TargetType="ScrollBar">
    <Grid x:Name="Bg"
          Height="{TemplateBinding Height}"
          Background="Transparent"
          SnapsToDevicePixels="True">
      <Track x:Name="PART_Track" IsDirectionReversed="False" Focusable="False">
        <Track.DecreaseRepeatButton>
          <RepeatButton Command="ScrollBar.PageLeftCommand" Focusable="False" IsTabStop="False" Opacity="0" />
        </Track.DecreaseRepeatButton>
        <Track.IncreaseRepeatButton>
          <RepeatButton Command="ScrollBar.PageRightCommand" Focusable="False" IsTabStop="False" Opacity="0" />
        </Track.IncreaseRepeatButton>
        <Track.Thumb>
          <Thumb>
            <Thumb.Template>
              <ControlTemplate TargetType="Thumb">
                <Border x:Name="T"
                        Background="{StaticResource Cad.ScrollThumb}"
                        CornerRadius="4"
                        Margin="3,1"
                        SnapsToDevicePixels="True" />
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="T" Property="Background" Value="{StaticResource Cad.ScrollThumbHover}" />
                  </Trigger>
                  <Trigger Property="IsDragging" Value="True">
                    <Setter TargetName="T" Property="Background" Value="{StaticResource Cad.Accent}" />
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Thumb.Template>
          </Thumb>
        </Track.Thumb>
      </Track>
    </Grid>
  </ControlTemplate>

  <Style x:Key="CadBaseScrollBar" TargetType="ScrollBar">
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Width" Value="8" />
    <Setter Property="MinWidth" Value="8" />
    <Setter Property="MaxWidth" Value="8" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template" Value="{StaticResource CadScrollBarVertical}" />
    <Style.Triggers>
      <Trigger Property="Orientation" Value="Horizontal">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MaxWidth" Value="{x:Static sys:Double.PositiveInfinity}" />
        <Setter Property="Height" Value="8" />
        <Setter Property="MinHeight" Value="8" />
        <Setter Property="MaxHeight" Value="8" />
        <Setter Property="Template" Value="{StaticResource CadScrollBarHorizontal}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="ScrollBar" BasedOn="{StaticResource CadBaseScrollBar}" />

  <Style x:Key="CadBaseButton" TargetType="Button">
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Background" Value="#2D333B" />
    <Setter Property="Foreground" Value="#E6E8EA" />
    <Setter Property="BorderBrush" Value="#444C56" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="14,0" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="#2D333B"
                  BorderBrush="#444C56"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="4"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#363D47" />
              <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Cad.Accent}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#1E2630" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="#6D7682" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="Button" BasedOn="{StaticResource CadBaseButton}" />

  <Style x:Key="CadBasePrimaryButton" TargetType="Button" BasedOn="{StaticResource CadBaseButton}">
    <Setter Property="Background" Value="{StaticResource Cad.ButtonPrimary}" />
    <Setter Property="Foreground" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="{StaticResource Cad.ButtonPrimary}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="#1E77B4"
                  BorderBrush="#1E77B4"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="4"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#2386CC" />
              <Setter TargetName="Bd" Property="BorderBrush" Value="#2386CC" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#1664A8" />
              <Setter TargetName="Bd" Property="BorderBrush" Value="#1664A8" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="#6D7682" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource CadBasePrimaryButton}" />

  <Style x:Key="CadToolButton" TargetType="Button" BasedOn="{StaticResource CadBaseButton}">
    <Setter Property="MinWidth" Value="88" />
  </Style>

  <Style x:Key="CadToolbarMiniButton" TargetType="Button" BasedOn="{StaticResource CadBaseButton}">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style x:Key="CadPrimaryActionButton" TargetType="Button" BasedOn="{StaticResource CadBasePrimaryButton}">
    <Setter Property="MinWidth" Value="88" />
  </Style>

  <Style x:Key="CadRoundedTitleButton" TargetType="Button">
    <Setter Property="Width" Value="34" />
    <Setter Property="Height" Value="34" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#B6C1DD" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="Transparent"
                  CornerRadius="8">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#313750" />
              <Setter Property="Foreground" Value="#FFFFFF" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#202538" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CadRoundedIconButton" TargetType="Button" BasedOn="{StaticResource CadRoundedTitleButton}">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Foreground" Value="{StaticResource Cad.Muted}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="Transparent"
                  CornerRadius="8">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#313750" />
              <Setter Property="Foreground" Value="#FFFFFF" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CadToolbarIconButton" TargetType="Button">
    <Setter Property="Width" Value="34" />
    <Setter Property="MinWidth" Value="34" />
    <Setter Property="Height" Value="34" />
    <Setter Property="MinHeight" Value="30" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource Cad.Muted}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="Transparent"
                  CornerRadius="8">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#313750" />
              <Setter Property="Foreground" Value="#FFFFFF" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#202538" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CadToolbarIconButtonLarge" TargetType="Button" BasedOn="{StaticResource CadToolbarIconButton}">
    <Setter Property="Width" Value="40" />
    <Setter Property="MinWidth" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="FontSize" Value="18" />
  </Style>

  <Style x:Key="CadRadioTabButton" TargetType="RadioButton">
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Foreground" Value="#8B949E" />
    <Setter Property="Background" Value="{StaticResource Cad.TabIdle}" />
    <Setter Property="BorderBrush" Value="{StaticResource Cad.Border}" />
    <Setter Property="BorderThickness" Value="1,1,1,0" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="Margin" Value="0,0,2,0" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Grid Margin="{TemplateBinding Margin}">
            <Border x:Name="TabBd"
                    Background="{StaticResource Cad.TabIdle}"
                    BorderBrush="{StaticResource Cad.Border}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="0"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Border>
            <Border x:Name="TabAccent"
                    Height="2"
                    VerticalAlignment="Bottom"
                    Background="Transparent"
                    CornerRadius="0" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="TabBd" Property="Background" Value="{StaticResource Cad.TabSelected}" />
              <Setter TargetName="TabAccent" Property="Background" Value="{StaticResource Cad.Accent}" />
              <Setter Property="Foreground" Value="#FFFFFF" />
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsChecked" Value="False" />
                <Condition Property="IsMouseOver" Value="True" />
              </MultiTrigger.Conditions>
              <Setter TargetName="TabBd" Property="Background" Value="{StaticResource Cad.TabHover}" />
              <Setter Property="Foreground" Value="#E6E8EA" />
            </MultiTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CadAccentCheckBoxBase" TargetType="CheckBox">
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <Grid Width="18" Height="18" SnapsToDevicePixels="True">
            <Border x:Name="Bd"
                    Width="18"
                    Height="18"
                    CornerRadius="0"
                    BorderBrush="#FFFFFF"
                    BorderThickness="1"
                    Background="Transparent" />
            <Path x:Name="Mark"
                  Data="M 4,9.5 L 7.5,13 L 14,5"
                  Stroke="White"
                  StrokeThickness="2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Fill="{x:Null}"
                  Visibility="Collapsed"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{StaticResource Cad.Accent}" />
              <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Cad.Accent}" />
              <Setter TargetName="Mark" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Cad.Accent}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
              <Setter TargetName="Mark" Property="Opacity" Value="0.45" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CadWidePageWindow" TargetType="Window">
    <Setter Property="WindowStyle" Value="SingleBorderWindow" />
    <Setter Property="ResizeMode" Value="CanResize" />
    <Setter Property="ShowInTaskbar" Value="False" />
    <Setter Property="ShowActivated" Value="False" />
    <Setter Property="Topmost" Value="False" />
    <!-- AutoCAD 2024 模型窗口首帧套模板时，跨字典 DynamicResource 可能短暂给出 UnsetValue。 -->
    <Setter Property="Background" Value="#262C38" />
    <Setter Property="BorderBrush" Value="#21262D" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="#E8EAED" />
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style x:Key="CadWidePageFrame" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Cad.Panel}" />
    <Setter Property="BorderBrush" Value="{StaticResource Cad.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <Style x:Key="CadInfoChip" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Cad.InputBg}" />
    <Setter Property="BorderBrush" Value="{StaticResource Cad.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style x:Key="CadWidePageToolbar" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Cad.ToolbarBg}" />
    <Setter Property="BorderBrush" Value="{StaticResource Cad.Border}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="16,14" />
  </Style>

  <Style x:Key="CadWidePageTabsBar" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Cad.RowAlt}" />
    <Setter Property="BorderBrush" Value="{StaticResource Cad.Border}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="MinHeight" Value="56" />
    <Setter Property="Padding" Value="14,0,14,0" />
  </Style>

  <Style x:Key="CadWidePageStatusBar" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Cad.RowAlt}" />
    <Setter Property="BorderBrush" Value="{StaticResource Cad.StatusLine}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="14,10" />
  </Style>

  <Style x:Key="CadWidePageStatusText" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource Cad.Muted}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style x:Key="CadBaseTextBox" TargetType="TextBox">
    <Setter Property="Background" Value="{StaticResource Cad.InputBg}" />
    <Setter Property="Foreground" Value="#E6E8EA" />
    <Setter Property="BorderBrush" Value="{StaticResource Cad.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CaretBrush" Value="#E6E8EA" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="Bd"
                  Background="{StaticResource Cad.InputBg}"
                  BorderBrush="{StaticResource Cad.Border}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="4"
                  Padding="{TemplateBinding Padding}">
            <ScrollViewer x:Name="PART_ContentHost"
                          Focusable="False"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsFocused" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Cad.Accent}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="TextBox" BasedOn="{StaticResource CadBaseTextBox}" />

  <Style x:Key="CadAutoScrollTextBox" TargetType="TextBox">
    <Setter Property="Background" Value="{StaticResource Cad.InputBg}" />
    <Setter Property="Foreground" Value="#E6E8EA" />
    <Setter Property="BorderBrush" Value="{StaticResource Cad.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CaretBrush" Value="#E6E8EA" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="Bd"
                  Background="{StaticResource Cad.InputBg}"
                  BorderBrush="{StaticResource Cad.Border}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="4"
                  Padding="{TemplateBinding Padding}">
            <ScrollViewer x:Name="PART_ContentHost"
                          Focusable="False"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Hidden" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsFocused" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Cad.Accent}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CadReadOnlyPathTextBox" TargetType="TextBox" BasedOn="{StaticResource CadAutoScrollTextBox}">
    <Setter Property="IsReadOnly" Value="True" />
  </Style>

  <Style x:Key="CadCompactReadOnlyPathTextBox" TargetType="TextBox" BasedOn="{StaticResource CadReadOnlyPathTextBox}">
    <Setter Property="Height" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="8,0" />
  </Style>

  <Style x:Key="CadSearchIconControl" TargetType="ContentControl">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Foreground" Value="{DynamicResource Cad.Muted}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContentControl">
          <Viewbox Width="{TemplateBinding Width}"
                   Height="{TemplateBinding Height}"
                   Stretch="Uniform"
                   SnapsToDevicePixels="True">
            <Canvas Width="103.4"
                    Height="103.41">
              <Canvas.RenderTransform>
                <TranslateTransform X="-6.07" Y="-0.61" />
              </Canvas.RenderTransform>
              <Ellipse Canvas.Left="9.07"
                       Canvas.Top="3.61"
                       Width="75"
                       Height="75"
                       Stroke="{TemplateBinding Foreground}"
                       StrokeThickness="6" />
              <Line X1="78.47"
                    Y1="73.02"
                    X2="106.47"
                    Y2="101.02"
                    Stroke="{TemplateBinding Foreground}"
                    StrokeThickness="6"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round" />
            </Canvas>
          </Viewbox>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CadSearchFieldBorder" TargetType="Border">
    <Setter Property="Height" Value="32" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Background" Value="{DynamicResource Cad.InputBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Cad.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <Style x:Key="CadFolderIconControl" TargetType="ContentControl">
    <Setter Property="Width" Value="18" />
