<UserControl x:Class="C_toolsPlugin.PrintSavePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#16191F"
             Foreground="#E8EAED"
             FontFamily="Microsoft YaHei UI, Segoe UI"
             FontSize="12"
             Loaded="PrintSavePanel_OnLoaded">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/C_toolsShared;component/Themes/CadTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>

    <SolidColorBrush x:Key="Cad.Panel" Color="#262C38" />
    <SolidColorBrush x:Key="Cad.Border" Color="#21262D" />
    <SolidColorBrush x:Key="Cad.Muted" Color="#8B949E" />
    <SolidColorBrush x:Key="Cad.Accent" Color="#58A6FF" />
    <SolidColorBrush x:Key="Cad.InputBg" Color="#262C38" />
    <SolidColorBrush x:Key="Cad.GridBg" Color="#16191F" />
    <SolidColorBrush x:Key="Cad.GridHeaderBg" Color="#1B1F28" />
    <SolidColorBrush x:Key="Cad.GridRow" Color="#12141A" />
    <SolidColorBrush x:Key="Cad.GridRowAlt" Color="#12141A" />
    <SolidColorBrush x:Key="Cad.GridRowHover" Color="#222731" />
    <SolidColorBrush x:Key="Cad.ScrollTrack" Color="#10151C" />
    <SolidColorBrush x:Key="Cad.ScrollThumb" Color="#3D4756" />
    <SolidColorBrush x:Key="Cad.ScrollThumbHover" Color="#4E5A6A" />
    <SolidColorBrush x:Key="Cad.ButtonPrimary" Color="#1E77B4" />
    <SolidColorBrush x:Key="Cad.ToolbarBg" Color="#323B4A" />
    <SolidColorBrush x:Key="Cad.StatusLine" Color="#30363D" />

    <Style TargetType="TextBox" BasedOn="{StaticResource CadBaseTextBox}">
      <Setter Property="MinHeight" Value="30" />
    </Style>
    <Style x:Key="PrintSaveOptionCheckBox" TargetType="CheckBox">
      <Setter Property="Foreground" Value="#E6E8EA" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Border Background="Transparent" Padding="0,2">
              <StackPanel Orientation="Horizontal">
                <Grid Width="22" Height="22" VerticalAlignment="Center">
                  <Border x:Name="Box"
                          Width="18"
                          Height="18"
                          Background="#1F2535"
                          BorderBrush="#6C789A"
                          BorderThickness="1.2"
                          CornerRadius="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
                  <Path x:Name="CheckMark"
                        Data="M 4 9 L 7.5 12.5 L 14 6"
                        Stroke="White"
                        StrokeThickness="2"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Grid>
                <ContentPresenter Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  RecognizesAccessKey="True" />
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Box" Property="Background" Value="{StaticResource Cad.Accent}" />
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Cad.Accent}" />
                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                <Setter Property="Foreground" Value="#FFFFFF" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Cad.Accent}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="PrintSaveOptionRadioButton" TargetType="RadioButton">
      <Setter Property="Foreground" Value="#E6E8EA" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border Background="Transparent" Padding="0,2">
              <StackPanel Orientation="Horizontal">
                <Grid Width="22" Height="22" VerticalAlignment="Center">
                  <Ellipse x:Name="OuterDot"
                           Width="18"
                           Height="18"
                           Stroke="#6C789A"
                           StrokeThickness="1.2"
                           Fill="Transparent"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                  <Ellipse x:Name="InnerDot"
                           Width="9"
                           Height="9"
                           Fill="{StaticResource Cad.Accent}"
                           Visibility="Collapsed"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Grid>
                <ContentPresenter Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  RecognizesAccessKey="True" />
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="OuterDot" Property="Stroke" Value="{StaticResource Cad.Accent}" />
                <Setter TargetName="OuterDot" Property="Fill" Value="#22355F" />
                <Setter TargetName="InnerDot" Property="Visibility" Value="Visible" />
                <Setter Property="Foreground" Value="#FFFFFF" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="OuterDot" Property="Stroke" Value="{StaticResource Cad.Accent}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    </ResourceDictionary>
  </UserControl.Resources>
  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="16,0,16,12">
      <StackPanel>
        <TextBlock Text="V_QQQ 会读取这里保存的打印与保存设置。点击窗口右上角“保存”后，会写入共享配置；若当前有活动图纸，也会同步应用到当前布局。"
                   Foreground="{StaticResource Cad.Muted}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <Border Background="{StaticResource Cad.GridBg}"
                BorderBrush="{StaticResource Cad.Border}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16"
                Margin="0,0,0,12">
          <StackPanel>
            <TextBlock Text="打印机 / 图纸 / 打印样式表"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <Grid Margin="0,14,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0"
                         Grid.Column="0"
                         VerticalAlignment="Center"
                         Foreground="{StaticResource Cad.Muted}"
                         Text="打印机 / 绘图仪" />
              <Border Grid.Row="0"
                      Grid.Column="1"
                      Height="32"
                      Background="{StaticResource Cad.InputBg}"
                      BorderBrush="{StaticResource Cad.Border}"
                      BorderThickness="1"
                      CornerRadius="4">
                <ComboBox x:Name="PrinterCombo"
                          Style="{StaticResource CadToolbarComboBox}"
                          VerticalAlignment="Stretch"
                          SelectionChanged="PrinterCombo_SelectionChanged" />
              </Border>

              <TextBlock Grid.Row="1"
                         Grid.Column="0"
                         VerticalAlignment="Center"
                         Margin="0,10,0,0"
                         Foreground="{StaticResource Cad.Muted}"
                         Text="图纸尺寸" />
              <Border Grid.Row="1"
                      Grid.Column="1"
                      Height="32"
                      Margin="0,10,0,0"
                      Background="{StaticResource Cad.InputBg}"
                      BorderBrush="{StaticResource Cad.Border}"
                      BorderThickness="1"
                      CornerRadius="4">
                <ComboBox x:Name="MediaCombo"
                          Style="{StaticResource CadToolbarComboBox}"
                          VerticalAlignment="Stretch"
                          IsEditable="False" />
              </Border>

              <TextBlock Grid.Row="2"
                         Grid.Column="0"
                         VerticalAlignment="Center"
                         Margin="0,10,0,0"
                         Foreground="{StaticResource Cad.Muted}"
                         Text="打印样式表（CTB / STB）" />
              <Border Grid.Row="2"
                      Grid.Column="1"
                      Height="32"
                      Margin="0,10,0,0"
                      Background="{StaticResource Cad.InputBg}"
                      BorderBrush="{StaticResource Cad.Border}"
                      BorderThickness="1"
                      CornerRadius="4">
                <ComboBox x:Name="StyleCombo"
                          Style="{StaticResource CadToolbarComboBox}"
                          VerticalAlignment="Stretch"
                          IsEditable="False" />
              </Border>
            </Grid>
          </StackPanel>
        </Border>

        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0"
                  Background="{StaticResource Cad.GridBg}"
                  BorderBrush="{StaticResource Cad.Border}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="16">
            <StackPanel>
              <TextBlock Text="打印偏移"
                         FontSize="13"
                         FontWeight="SemiBold" />
              <CheckBox x:Name="CenterPlotCheckBox"
                        Style="{StaticResource PrintSaveOptionCheckBox}"
                        Content="居中打印"
                        Margin="0,14,0,0"
                        IsChecked="True"
                        Checked="CenterPlotCheckBox_Changed"
                        Unchecked="CenterPlotCheckBox_Changed" />
              <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="28" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="54" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Cad.Muted}"
                           Text="X:" />
                <TextBox x:Name="OffsetXBox"
                         Grid.Column="1"
                         VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource Cad.Muted}"
                           Text="毫米" />
              </Grid>
              <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="28" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="54" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Cad.Muted}"
                           Text="Y:" />
                <TextBox x:Name="OffsetYBox"
                         Grid.Column="1"
                         VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource Cad.Muted}"
                           Text="毫米" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Grid.Column="2"
                  Background="{StaticResource Cad.GridBg}"
                  BorderBrush="{StaticResource Cad.Border}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="16">
            <StackPanel>
              <TextBlock Text="打印比例"
                         FontSize="13"
                         FontWeight="SemiBold" />
              <CheckBox x:Name="FitToPaperCheckBox"
                        Style="{StaticResource PrintSaveOptionCheckBox}"
                        Content="布满图纸"
                        Margin="0,14,0,0"
                        IsChecked="True"
                        Checked="FitToPaperCheckBox_Changed"
                        Unchecked="FitToPaperCheckBox_Changed" />
              <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="64" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Cad.Muted}"
                           Text="比例" />
                <Border Grid.Column="1"
                        Height="32"
                        Background="{StaticResource Cad.InputBg}"
                        BorderBrush="{StaticResource Cad.Border}"
                        BorderThickness="1"
                        CornerRadius="4">
                  <ComboBox x:Name="ScaleCombo"
                            Style="{StaticResource CadToolbarComboBox}"
                            VerticalAlignment="Stretch"
                            IsEditable="True"
                            IsTextSearchEnabled="False" />
                </Border>
              </Grid>
              <CheckBox x:Name="ScaleLineweightsCheckBox"
                        Style="{StaticResource PrintSaveOptionCheckBox}"
                        Content="缩放线宽"
                        Margin="0,12,0,0"
                        IsChecked="True" />
            </StackPanel>
          </Border>

          <Border Grid.Column="4"
                  Background="{StaticResource Cad.GridBg}"
                  BorderBrush="{StaticResource Cad.Border}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="16">
            <StackPanel>
              <TextBlock Text="图形方向"
                         FontSize="13"
                         FontWeight="SemiBold" />
              <CheckBox x:Name="AutoMatchOrientationCheckBox"
                        Style="{StaticResource PrintSaveOptionCheckBox}"
                        Content="自动匹配图形方向"
                        Margin="0,14,0,0"
                        Checked="AutoMatchOrientationCheckBox_Changed"
                        Unchecked="AutoMatchOrientationCheckBox_Changed" />
              <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <RadioButton x:Name="PortraitRadio"
                             Style="{StaticResource PrintSaveOptionRadioButton}"
                             GroupName="PlotOrientationGroup"
                             Content="纵向"
                             VerticalAlignment="Center" />
                <RadioButton x:Name="LandscapeRadio"
                             Style="{StaticResource PrintSaveOptionRadioButton}"
                             GroupName="PlotOrientationGroup"
                             Content="横向"
                             Margin="18,0,0,0"
                             VerticalAlignment="Center"
                             IsChecked="True" />
                <CheckBox x:Name="UpsideDownCheckBox"
                          Style="{StaticResource PrintSaveOptionCheckBox}"
                          Content="上下颠倒打印"
                          Margin="18,0,0,0"
                          VerticalAlignment="Center" />
              </StackPanel>
              <Grid Margin="0,14,0,0">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Cad.Muted}"
                           Text="打印图纸顺序" />
                <Border Grid.Row="1"
                        Height="32"
                        Margin="0,8,0,0"
                        Background="{StaticResource Cad.InputBg}"
                        BorderBrush="{StaticResource Cad.Border}"
                        BorderThickness="1"
                        CornerRadius="4">
                  <ComboBox x:Name="PrintOrderCombo"
                            Style="{StaticResource CadToolbarComboBox}"
                            VerticalAlignment="Stretch"
                            IsEditable="False" />
                </Border>
              </Grid>
              <TextBlock Text="V_QQQ 合并 PDF 时会按这里的顺序排列图纸。"
                         Foreground="{StaticResource Cad.Muted}"
                         FontSize="11"
                         TextWrapping="Wrap"
                         Margin="0,10,0,0" />
            </StackPanel>
          </Border>
        </Grid>

        <Border Background="{StaticResource Cad.GridBg}"
                BorderBrush="{StaticResource Cad.Border}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16">
          <StackPanel>
            <TextBlock Text="保存行为"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         VerticalAlignment="Center"
                         Foreground="{StaticResource Cad.Muted}"
                         Text="CAD 图纸默认保存目录" />
              <TextBox Grid.Column="1"
                       x:Name="AutoSaveRootBox"
                       VerticalAlignment="Center" />
            </Grid>
            <Grid Margin="0,10,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         VerticalAlignment="Center"
                         Foreground="{StaticResource Cad.Muted}"
                         Text="自动 QSAVE 间隔（分钟）" />
              <TextBox Grid.Column="1"
                       x:Name="IntervalMinutesBox"
                       VerticalAlignment="Center" />
            </Grid>
            <TextBlock Text="自动 QSAVE 仅对当前活动图纸生效；输入 0 表示关闭。"
                       Foreground="{StaticResource Cad.Muted}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0" />
          </StackPanel>
        </Border>

        <TextBlock Text="使用窗口右上角“保存”写入打印与保存设置；保存成功后，V_QQQ 会按这里的参数出图。"
                   Foreground="{StaticResource Cad.Muted}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
