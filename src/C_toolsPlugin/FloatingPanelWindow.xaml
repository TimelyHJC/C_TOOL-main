<Window x:Class="C_toolsPlugin.FloatingPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:shared="clr-namespace:C_toolsShared;assembly=C_toolsShared"
        Title="C_TOOL 快捷键"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False"
        Background="#262C38"
        BorderBrush="#21262D"
        BorderThickness="1"
        Foreground="#E8EAED"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="12"
        Width="1920"
        Height="1080"
        MinWidth="960"
        MinHeight="540">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/C_toolsShared;component/Themes/CadTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- 独立宿主下优先使用本地 Cad 颜色键，避免 merged dictionary 的 StaticResource 在模板装载期解析失败 -->
      <SolidColorBrush x:Key="Cad.Panel" Color="#262C38" />
      <SolidColorBrush x:Key="Cad.Border" Color="#21262D" />
      <SolidColorBrush x:Key="Cad.Muted" Color="#8B949E" />
      <SolidColorBrush x:Key="Cad.Accent" Color="#58A6FF" />
      <SolidColorBrush x:Key="Cad.RowAlt" Color="#262C38" />
      <SolidColorBrush x:Key="Cad.HeaderBg" Color="#262C38" />
      <SolidColorBrush x:Key="Cad.InputBg" Color="#262C38" />
      <SolidColorBrush x:Key="Cad.GridBg" Color="#16191F" />
      <SolidColorBrush x:Key="Cad.GridHeaderBg" Color="#1B1F28" />
      <SolidColorBrush x:Key="Cad.GridRow" Color="#12141A" />
      <SolidColorBrush x:Key="Cad.GridRowAlt" Color="#12141A" />
      <SolidColorBrush x:Key="Cad.GridLine" Color="#252B36" />
      <SolidColorBrush x:Key="Cad.GridRowHover" Color="#222731" />
      <SolidColorBrush x:Key="Cad.ScrollTrack" Color="#10151C" />
      <SolidColorBrush x:Key="Cad.ScrollThumb" Color="#3D4756" />
      <SolidColorBrush x:Key="Cad.ScrollThumbHover" Color="#4E5A6A" />
      <SolidColorBrush x:Key="Cad.ButtonPrimary" Color="#1E77B4" />
      <SolidColorBrush x:Key="Cad.ToolbarBg" Color="#323B4A" />
      <SolidColorBrush x:Key="Cad.StatusLine" Color="#30363D" />
      <SolidColorBrush x:Key="Cad.TabIdle" Color="#262C38" />
      <SolidColorBrush x:Key="Cad.TabHover" Color="#2C3340" />
      <SolidColorBrush x:Key="Cad.TabSelected" Color="#262C38" />

      <shared:DataGridRowIndexConverter x:Key="RowIndexConverter" />
      <SolidColorBrush x:Key="Cad.StatusSuccess" Color="#9BCBFF" />
      <SolidColorBrush x:Key="Cad.StatusError" Color="#FF7B5C" />

      <Style TargetType="Border">
        <Setter Property="BorderBrush" Value="Transparent" />
      </Style>

      <Style x:Key="ToolbarMiniButton" TargetType="Button" BasedOn="{StaticResource CadToolbarMiniButton}" />

      <Style x:Key="ToolbarIconButton" TargetType="Button" BasedOn="{StaticResource CadToolbarIconButton}" />

      <Style x:Key="ToolbarIconButtonLarge" TargetType="Button" BasedOn="{StaticResource CadToolbarIconButtonLarge}" />

      <Style x:Key="ToolbarRefreshButton" TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
        <Setter Property="Width" Value="34" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Grid Width="{TemplateBinding Width}"
                    Height="{TemplateBinding Height}">
                <Ellipse x:Name="Bd"
                         Fill="Transparent" />
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Fill" Value="#313750" />
                  <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Bd" Property="Fill" Value="#202538" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="ToolbarRefreshIcon" TargetType="ContentControl">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Foreground" Value="{StaticResource Cad.Muted}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ContentControl">
              <Viewbox Width="{TemplateBinding Width}"
                       Height="{TemplateBinding Height}"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True">
                <Canvas Width="24"
                        Height="24">
                  <Path Stroke="{TemplateBinding Foreground}"
                        StrokeThickness="2"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        Data="M21,12 A9,9 0 1 1 18.36,5.64" />
                  <Polyline Points="21,3 21,8 16,8"
                            Stroke="{TemplateBinding Foreground}"
                            StrokeThickness="2"
                            StrokeStartLineCap="Round"
                            StrokeEndLineCap="Round"
                            StrokeLineJoin="Round" />
                </Canvas>
              </Viewbox>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="ToolbarIconToggleButtonLarge" TargetType="ToggleButton">
        <Setter Property="Width" Value="40" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Cad.Muted}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ToggleButton">
              <Border x:Name="Bd"
                      Background="Transparent"
                      CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#313750" />
                  <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="{StaticResource Cad.ButtonPrimary}" />
                  <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#202538" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="HatchCellButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource Cad.Accent}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Foreground" Value="#E6F1FF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter Property="Foreground" Value="#C5E0FF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Foreground" Value="#6D7682" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Style.Triggers>
          <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
            <Setter Property="Foreground" Value="{StaticResource Cad.StatusSuccess}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
          </DataTrigger>
        </Style.Triggers>
      </Style>

      <Style x:Key="LegacyTabItem" TargetType="TabItem">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="#8B949E" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Margin" Value="0,0,2,0" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="TabItem">
              <Grid Margin="{TemplateBinding Margin}">
                <Border x:Name="TabBorder"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                  <ContentPresenter x:Name="ContentSite"
                                    ContentSource="Header"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RecognizesAccessKey="True" />
                </Border>
                <Border x:Name="TabAccent"
                        Height="2"
                        VerticalAlignment="Bottom"
                        Background="Transparent"
                        CornerRadius="0" />
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="IsSelected" Value="True">
                  <Setter TargetName="TabAccent" Property="Background" Value="{StaticResource Cad.Accent}" />
                  <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <MultiTrigger>
                  <MultiTrigger.Conditions>
                    <Condition Property="IsSelected" Value="False" />
                    <Condition Property="IsMouseOver" Value="True" />
                  </MultiTrigger.Conditions>
                  <Setter Property="Foreground" Value="#E6E8EA" />
                </MultiTrigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Opacity" Value="0.6" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="LegacyTabs" TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource Cad.Panel}" />
        <Setter Property="BorderBrush" Value="{StaticResource Cad.Border}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource LegacyTabItem}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="TabControl">
              <Grid KeyboardNavigation.TabNavigation="Local"
                    SnapsToDevicePixels="True"
                    ClipToBounds="True">
                <Grid.RowDefinitions>
                  <RowDefinition Height="56" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="{StaticResource Cad.RowAlt}"
                        BorderBrush="{StaticResource Cad.Border}"
                        BorderThickness="0,0,0,1">
                  <TabPanel x:Name="HeaderPanel"
                            Margin="14,0,164,0"
                            VerticalAlignment="Stretch"
                            IsItemsHost="True"
                            Panel.ZIndex="1"
                            KeyboardNavigation.TabIndex="1" />
                </Border>
                <ContentPresenter x:Name="PART_SelectedContentHost"
                                  Grid.Row="1"
                                  ContentSource="SelectedContent"
                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                  KeyboardNavigation.TabIndex="2" />
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
      <Setter Property="Foreground" Value="#E6E8EA" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="16,16" />
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="DataGridColumnHeader">
            <Border x:Name="HeaderBorder"
                    BorderBrush="Transparent"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Background="{StaticResource Cad.GridHeaderBg}">
              <ContentPresenter Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                SnapsToDevicePixels="True" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      </Style>

      <Style x:Key="DgHeaderFirstColumn" TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeader}">
      <Setter Property="Padding" Value="16,16" />
      </Style>

      <Style x:Key="DgHeaderIndexColumn" TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeader}">
      <Setter Property="Padding" Value="4,16" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      </Style>
      <Style x:Key="DgHeaderSpacerColumn" TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeader}">
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      </Style>

      <Style x:Key="CadGridSelectAllButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      </Style>

    <Style x:Key="CadDataGridCell" TargetType="DataGridCell">
      <Setter Property="Foreground" Value="#E6E8EA" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FontSize" Value="13" />
      <Style.Triggers>
        <!-- 选中行不显式高亮条，与斑马纹一致；悬停仍用 GridRowHover -->
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Foreground" Value="#E6E8EA" />
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{StaticResource Cad.GridRowHover}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CadDataGridCellIndexColumn" TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCell}">
      <Setter Property="Padding" Value="4,0,4,0" />
      <Setter Property="Foreground" Value="Transparent" />
    </Style>
    <Style x:Key="CadDataGridCellSpacerColumn" TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCell}">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="Transparent" />
    </Style>
    <Style x:Key="CadDataGridCellFillColumn" TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCell}">
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>

    <Style TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCell}" />
    <Style x:Key="CadDataGridCellFirstColumn" TargetType="DataGridCell" BasedOn="{StaticResource CadDataGridCell}">
      <Setter Property="Padding" Value="16,0,16,0" />
    </Style>

    <Style x:Key="CadDgCellTextBlock" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style x:Key="CadDgCellTextBlockCenter" TargetType="TextBlock" BasedOn="{StaticResource CadDgCellTextBlock}">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style x:Key="CadDgCellTextBox" TargetType="TextBox">
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style x:Key="CadDgCellTextBoxCenter" TargetType="TextBox" BasedOn="{StaticResource CadDgCellTextBox}">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style x:Key="CadDataGrid" TargetType="DataGrid">
      <!-- 须用 Style.Resources，勿用 Setter Property=Resources（运行时会抛 Setter.Property 异常） -->
      <Style.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E6E8EA" />
        <Style TargetType="ScrollBar">
          <Setter Property="Width" Value="0" />
          <Setter Property="Height" Value="0" />
          <Setter Property="Opacity" Value="0" />
          <Setter Property="IsHitTestVisible" Value="False" />
          <Setter Property="Focusable" Value="False" />
        </Style>
      </Style.Resources>
      <Setter Property="RowHeight" Value="36" />
      <Setter Property="Background" Value="{StaticResource Cad.GridBg}" />
      <Setter Property="Foreground" Value="#E6E8EA" />
      <Setter Property="BorderBrush" Value="{StaticResource Cad.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Cad.GridLine}" />
      <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
      <Setter Property="RowBackground" Value="{StaticResource Cad.GridRow}" />
      <Setter Property="AlternatingRowBackground" Value="{StaticResource Cad.GridRowAlt}" />
      <Setter Property="ColumnHeaderStyle" Value="{StaticResource DgHeader}" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="RowHeaderWidth" Value="0" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="EnableRowVirtualization" Value="True" />
      <Setter Property="EnableColumnVirtualization" Value="True" />
      <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
      <Setter Property="ScrollViewer.PanningMode" Value="Both" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="DataGrid">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="0"
                    SnapsToDevicePixels="True">
              <ScrollViewer x:Name="DG_ScrollViewer"
                            Focusable="False"
                            CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                            PanningMode="{TemplateBinding ScrollViewer.PanningMode}">
                <ScrollViewer.Template>
                  <ControlTemplate TargetType="ScrollViewer">
                    <Grid Background="Transparent">
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="0" />
                      </Grid.RowDefinitions>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="0" />
                      </Grid.ColumnDefinitions>

                      <Button Grid.Row="0"
                              Grid.Column="0"
                              Width="{Binding CellsPanelHorizontalOffset, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                              Command="{x:Static DataGrid.SelectAllCommand}"
                              Focusable="False"
                              Style="{StaticResource CadGridSelectAllButton}"
                              Visibility="{Binding HeadersVisibility, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, ConverterParameter={x:Static DataGridHeadersVisibility.All}}" />

                      <DataGridColumnHeadersPresenter x:Name="PART_ColumnHeadersPresenter"
                                                      Grid.Row="0"
                                                      Grid.Column="1"
                                                      Visibility="{Binding HeadersVisibility, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, ConverterParameter={x:Static DataGridHeadersVisibility.Column}}" />

                      <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                              Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              CanContentScroll="{TemplateBinding CanContentScroll}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />

                      <Border Grid.Row="0"
                              Grid.RowSpan="2"
                              Grid.Column="2"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              BorderThickness="0"
                              Visibility="Collapsed">
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Margin="2,4,2,4"
                                   Visibility="Collapsed"
                                   IsHitTestVisible="False"
                                   Orientation="Vertical"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                      </Border>

                      <Border Grid.Row="2"
                              Grid.Column="0"
                              Grid.ColumnSpan="2"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              BorderThickness="0"
                              Visibility="Collapsed">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding NonFrozenColumnsViewportHorizontalOffset, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <ScrollBar x:Name="PART_HorizontalScrollBar"
                                     Grid.Column="1"
                                     Margin="4,2,4,2"
                                     Visibility="Collapsed"
                                     IsHitTestVisible="False"
                                     Orientation="Horizontal"
                                     Maximum="{TemplateBinding ScrollableWidth}"
                                     ViewportSize="{TemplateBinding ViewportWidth}"
                                     Value="{Binding HorizontalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                        </Grid>
                      </Border>

                      <Border Grid.Row="2"
                              Grid.Column="2"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              BorderThickness="0"
                              Visibility="{Binding ComputedVerticalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}" />
                    </Grid>
                  </ControlTemplate>
                </ScrollViewer.Template>
                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
              </ScrollViewer>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- HTML .checkbox accent-color: #58a6ff -->
    <Style x:Key="CadAccentCheckBox" TargetType="CheckBox" BasedOn="{StaticResource CadAccentCheckBoxBase}" />
    <Style x:Key="CadCircleCheckBox" TargetType="CheckBox">
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Grid Width="18" Height="18" SnapsToDevicePixels="True">
              <Ellipse x:Name="OuterRing"
                       Width="16"
                       Height="16"
                       Stroke="#FFFFFF"
                       StrokeThickness="1.4"
                       Fill="Transparent"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
              <Ellipse x:Name="InnerDot"
                       Width="8"
                       Height="8"
                       Fill="{StaticResource Cad.Accent}"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="OuterRing" Property="Stroke" Value="{StaticResource Cad.Accent}" />
                <Setter TargetName="InnerDot" Property="Visibility" Value="Visible" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="OuterRing" Property="Stroke" Value="{StaticResource Cad.Accent}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="OuterRing" Property="Opacity" Value="0.9" />
                <Setter TargetName="InnerDot" Property="Opacity" Value="0.9" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="OuterRing" Property="Opacity" Value="0.38" />
                <Setter TargetName="InnerDot" Property="Opacity" Value="0.38" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="CadPropertySectionTitle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="CadPropertySectionHint" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Cad.Muted}" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style x:Key="CadPropertyLabelText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#D0D7DE" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style x:Key="CadPropertyValueBorder" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource Cad.GridRow}" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="MinHeight" Value="34" />
    </Style>
    <Style x:Key="CadPropertyValueText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#F3F4F6" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Background="{StaticResource Cad.Panel}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

        <!-- ui-optimization-final.html .toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource Cad.ToolbarBg}"
                BorderBrush="{StaticResource Cad.Border}"
                BorderThickness="0,0,0,1"
                Padding="16,14">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0">
              <ContentControl Style="{StaticResource CadSearchIconControl}"
                              Width="16"
                              Height="16"
                              Margin="0,0,8,0"
                              VerticalAlignment="Center" />
              <Border Width="200"
                      MinWidth="160"
                      MaxWidth="260"
                      Style="{StaticResource CadSearchFieldBorder}">
                <Grid>
                  <TextBlock x:Name="TxtCatalogFilterPlaceholder"
                             Margin="10,0,8,0"
                             VerticalAlignment="Center"
                             FontSize="13"
                             Foreground="#6D7682"
                             IsHitTestVisible="False"
                             Text="筛选..." />
                  <TextBox x:Name="TxtCatalogFilter"
                           Style="{StaticResource CadToolbarSearchBox}"
                           ToolTip="筛选当前标签页：别名、命令、说明、图层名称"
                           GotKeyboardFocus="TxtCatalogFilter_FocusChanged"
                           LostKeyboardFocus="TxtCatalogFilter_FocusChanged"
                           TextChanged="TxtCatalogFilter_OnTextChanged" />
                </Grid>
              </Border>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
              <Button x:Name="BtnLoadCurrentDrawingLayers"
                      Content="加载当前图纸图层"
                      MinWidth="132"
                      Margin="0,0,10,0"
                      ToolTip="读取当前 DWG 的图层表并追加到列表（不清空已有行；列表中已有同名图层会跳过）。仅填图层名与样式，快捷键请自行填写。"
                      Click="LoadCurrentDrawingLayers_Click" />
              <Button x:Name="BtnResetLayerShortcuts"
                      Content="重置快捷键"
                      MinWidth="96"
                      Margin="0,0,10,0"
                      ToolTip="用初始化文件.md 重置默认快捷键"
                      Click="ResetLayerShortcuts_Click" />
              <Button Content="保存"
                      MinWidth="72"
                      Style="{StaticResource PrimaryButton}"
                      Click="SaveToPgp_Click" />
            </StackPanel>
          </Grid>
        </Border>

        <TabControl x:Name="MainTabs"
                    Grid.Row="1"
                    Style="{StaticResource LegacyTabs}"
                    Background="{StaticResource Cad.Panel}"
                    BorderBrush="{StaticResource Cad.Border}"
                    BorderThickness="0"
                    SelectionChanged="MainTabs_SelectionChanged">
          <TabItem Header="图层命令">
            <Border Background="{StaticResource Cad.Panel}" Padding="0">
              <DataGrid x:Name="GridLayer"
                  Style="{StaticResource CadDataGrid}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  CellEditEnding="Grid_CellEditEnding"
                  PreviewKeyDown="GridLayer_PreviewKeyDown">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Click="DeleteLayerRows_ContextClick" Header="删除所选行" />
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <DataGridTemplateColumn Width="0"
                                    MinWidth="0"
                                    CanUserResize="False"
                                    IsReadOnly="True"
                                    HeaderStyle="{StaticResource DgHeaderIndexColumn}"
                                    CellStyle="{StaticResource CadDataGridCellIndexColumn}">
              <DataGridTemplateColumn.Header>
                <TextBlock Text="序号"
                           Foreground="Transparent"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Foreground="Transparent"
                             Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                            Path=.,
                                            Converter={StaticResource RowIndexConverter}}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="图层快捷键"
                                Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"
                                Width="*"
                                MinWidth="72"
                                HeaderStyle="{StaticResource DgHeaderFirstColumn}"
                                CellStyle="{StaticResource CadDataGridCellFirstColumn}"
                                ElementStyle="{StaticResource CadDgCellTextBlockCenter}"
                                EditingElementStyle="{StaticResource CadDgCellTextBoxCenter}" />
            <DataGridTextColumn Header="图层名称"
                                Binding="{Binding LayerName, UpdateSourceTrigger=PropertyChanged}"
                                Width="1.2*"
                                MinWidth="100"
                                ElementStyle="{StaticResource CadDgCellTextBlock}"
                                EditingElementStyle="{StaticResource CadDgCellTextBox}" />
            <DataGridTextColumn Header="颜色(ACI)"
                                Binding="{Binding LayerColor, UpdateSourceTrigger=PropertyChanged}"
                                Width="72"
                                MinWidth="64"
                                ElementStyle="{StaticResource CadDgCellTextBlockCenter}"
                                EditingElementStyle="{StaticResource CadDgCellTextBoxCenter}" />
            <DataGridTextColumn Header="说明"
                                Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                Width="1.2*"
                                MinWidth="100"
                                ElementStyle="{StaticResource CadDgCellTextBlock}"
                                EditingElementStyle="{StaticResource CadDgCellTextBox}" />
            <DataGridTemplateColumn Header="填充样式"
                                    Width="Auto"
                                    MinWidth="120"
                                    CellStyle="{StaticResource CadDataGridCellFillColumn}">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Button x:Name="HatchPickButton"
                          Style="{StaticResource HatchCellButton}"
                          Tag="{Binding LayerHatchPicked}"
                          Content="+"
                          Click="PickHatchStyle_Click"
                          ToolTip="在图纸中拾取填充样式" />
                    <DataTemplate.Triggers>
                      <DataTrigger Binding="{Binding LayerHatchPicked}" Value="True">
                        <Setter TargetName="HatchPickButton" Property="Content" Value="已拾取" />
                        <Setter TargetName="HatchPickButton" Property="ToolTip" Value="已拾取，点击可重新拾取" />
                      </DataTrigger>
                    </DataTemplate.Triggers>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="尺寸标注"
                                    Width="Auto"
                                    MinWidth="100">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <CheckBox Style="{StaticResource CadCircleCheckBox}"
                            IsChecked="{Binding LayerRunDimensionWhenNoSelection, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="{Binding LayerDimensionCheckboxEnabled}"
                            Click="LayerDimensionCheckbox_Click"
                            VerticalAlignment="Center"
                            Margin="4,0" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            <DataGridTemplateColumn Width="0"
                                    MinWidth="0"
                                    CanUserResize="False"
                                    CanUserSort="False"
                                    IsReadOnly="True"
                                    HeaderStyle="{StaticResource DgHeaderSpacerColumn}"
                                    CellStyle="{StaticResource CadDataGridCellSpacerColumn}">
              <DataGridTemplateColumn.Header>
                <TextBlock Text=""
                           Foreground="Transparent" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Border Background="Transparent" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
            </Border>
          </TabItem>

          <TabItem Header="CAD原生命令">
            <Border Background="{StaticResource Cad.Panel}" Padding="0">
        <DataGrid x:Name="GridCadNative"
                  Style="{StaticResource CadDataGrid}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  CellEditEnding="Grid_CellEditEnding">
          <DataGrid.Columns>
            <DataGridTemplateColumn Width="0"
                                    MinWidth="0"
                                    CanUserResize="False"
                                    IsReadOnly="True"
                                    HeaderStyle="{StaticResource DgHeaderIndexColumn}"
                                    CellStyle="{StaticResource CadDataGridCellIndexColumn}">
              <DataGridTemplateColumn.Header>
                <TextBlock Text="序号"
                           Foreground="Transparent"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Foreground="Transparent"
                             Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                            Path=.,
                                            Converter={StaticResource RowIndexConverter}}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="别名"
                                Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"
                                Width="*"
                                MinWidth="72"
                                HeaderStyle="{StaticResource DgHeaderFirstColumn}"
                                CellStyle="{StaticResource CadDataGridCellFirstColumn}"
                                ElementStyle="{StaticResource CadDgCellTextBlock}"
                                EditingElementStyle="{StaticResource CadDgCellTextBox}" />
            <DataGridTextColumn Header="命令"
                                Binding="{Binding CommandName, UpdateSourceTrigger=PropertyChanged}"
                                Width="*"
                                MinWidth="100"
                                IsReadOnly="True"
                                ElementStyle="{StaticResource CadDgCellTextBlock}"
                                EditingElementStyle="{StaticResource CadDgCellTextBox}" />
            <DataGridTextColumn Header="说明"
                                Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                Width="2*"
                                MinWidth="120"
                                ElementStyle="{StaticResource CadDgCellTextBlock}"
                                EditingElementStyle="{StaticResource CadDgCellTextBox}" />
            <DataGridTemplateColumn Width="0"
                                    MinWidth="0"
                                    CanUserResize="False"
                                    CanUserSort="False"
                                    IsReadOnly="True"
                                    HeaderStyle="{StaticResource DgHeaderSpacerColumn}"
                                    CellStyle="{StaticResource CadDataGridCellSpacerColumn}">
              <DataGridTemplateColumn.Header>
                <TextBlock Text=""
                           Foreground="Transparent" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Border Background="Transparent" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Border>
          </TabItem>

          <TabItem Header="V命令">
            <Border Background="{StaticResource Cad.Panel}" Padding="0">
        <DataGrid x:Name="GridVCommand"
                  Style="{StaticResource CadDataGrid}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  CellEditEnding="Grid_CellEditEnding">
          <DataGrid.Columns>
            <DataGridTemplateColumn Width="0"
                                    MinWidth="0"
                                    CanUserResize="False"
                                    IsReadOnly="True"
                                    HeaderStyle="{StaticResource DgHeaderIndexColumn}"
                                    CellStyle="{StaticResource CadDataGridCellIndexColumn}">
              <DataGridTemplateColumn.Header>
                <TextBlock Text="序号"
                           Foreground="Transparent"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Foreground="Transparent"
                             Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                            Path=.,
                                            Converter={StaticResource RowIndexConverter}}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="别名"
                                Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"
                                Width="*"
                                MinWidth="72"
                                HeaderStyle="{StaticResource DgHeaderFirstColumn}"
                                CellStyle="{StaticResource CadDataGridCellFirstColumn}"
                                ElementStyle="{StaticResource CadDgCellTextBlock}"
                                EditingElementStyle="{StaticResource CadDgCellTextBox}" />
            <DataGridTextColumn Header="命令"
                                Binding="{Binding CommandName, UpdateSourceTrigger=PropertyChanged}"
                                Width="*"
                                MinWidth="100"
                                IsReadOnly="True"
                                ElementStyle="{StaticResource CadDgCellTextBlock}"
                                EditingElementStyle="{StaticResource CadDgCellTextBox}" />
            <DataGridTextColumn Header="说明"
                                Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                Width="2*"
                                MinWidth="120"
                                ElementStyle="{StaticResource CadDgCellTextBlock}"
                                EditingElementStyle="{StaticResource CadDgCellTextBox}" />
            <DataGridTemplateColumn Width="0"
                                    MinWidth="0"
                                    CanUserResize="False"
                                    CanUserSort="False"
                                    IsReadOnly="True"
                                    HeaderStyle="{StaticResource DgHeaderSpacerColumn}"
                                    CellStyle="{StaticResource CadDataGridCellSpacerColumn}">
              <DataGridTemplateColumn.Header>
                <TextBlock Text=""
                           Foreground="Transparent" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Border Background="Transparent" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
            </Border>
          </TabItem>

          <TabItem Header="插件命令">
            <Border Background="{StaticResource Cad.Panel}" Padding="0">
        <DataGrid x:Name="GridPluginCommand"
                  Style="{StaticResource CadDataGrid}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  CellEditEnding="Grid_CellEditEnding">
          <DataGrid.Columns>
            <DataGridTemplateColumn Width="0"
                                    MinWidth="0"
                                    CanUserResize="False"
                                    IsReadOnly="True"
                                    HeaderStyle="{StaticResource DgHeaderIndexColumn}"
                                    CellStyle="{StaticResource CadDataGridCellIndexColumn}">
              <DataGridTemplateColumn.Header>
                <TextBlock Text="序号"
                           Foreground="Transparent"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Foreground="Transparent"
                             Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                            Path=.,
                                            Converter={StaticResource RowIndexConverter}}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="别名"
                                Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"
                                Width="*"
                                MinWidth="72"
                                HeaderStyle="{StaticResource DgHeaderFirstColumn}"
                                CellStyle="{StaticResource CadDataGridCellFirstColumn}"
                                ElementStyle="{StaticResource CadDgCellTextBlock}"
                                EditingElementStyle="{StaticResource CadDgCellTextBox}" />
            <DataGridTextColumn Header="命令"
                                Binding="{Binding CommandName, UpdateSourceTrigger=PropertyChanged}"
                                Width="*"
                                MinWidth="100"
                                IsReadOnly="True"
                                ElementStyle="{StaticResource CadDgCellTextBlock}"
                                EditingElementStyle="{StaticResource CadDgCellTextBox}" />
            <DataGridTextColumn Header="说明"
                                Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                Width="2*"
                                MinWidth="120"
                                ElementStyle="{StaticResource CadDgCellTextBlock}"
                                EditingElementStyle="{StaticResource CadDgCellTextBox}" />
            <DataGridTemplateColumn Width="0"
                                    MinWidth="0"
                                    CanUserResize="False"
                                    CanUserSort="False"
                                    IsReadOnly="True"
                                    HeaderStyle="{StaticResource DgHeaderSpacerColumn}"
                                    CellStyle="{StaticResource CadDataGridCellSpacerColumn}">
              <DataGridTemplateColumn.Header>
                <TextBlock Text=""
                           Foreground="Transparent" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Border Background="Transparent" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
            </Border>
          </TabItem>

        </TabControl>

        <StackPanel Grid.Row="1"
                    Panel.ZIndex="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,3,14,0">
          <Button x:Name="BtnImportLayerXlsx"
                  Style="{StaticResource ToolbarIconButton}"
                  Margin="0,0,8,0"
                  ToolTip="选择 .xlsx：首行为表头，需含「图层名称」列；可选「图层快捷键」「颜色」「线型」「线宽」「说明」「是否启用尺寸标注」。无表头时列顺序至 G（尺寸标注）。填充样式请在面板中点“拾取…”。与列表中“快捷键+图层名”完全相同的行会跳过。"
                  Click="ImportLayerXlsx_Click">
            <ContentControl Style="{StaticResource CadImportIconControl}"
                            Width="18"
                            Height="18"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground, FallbackValue={StaticResource Cad.Muted}, TargetNullValue={StaticResource Cad.Muted}}" />
          </Button>
          <Button x:Name="BtnAddLayerShortcut"
                  Style="{StaticResource ToolbarIconButtonLarge}"
                  Margin="0,0,8,0"
                  ToolTip="添加图层别名"
                  Click="AddLayerShortcutRow_Click">
            <ContentControl Style="{StaticResource CadAddIconControl}"
                            Width="18"
                            Height="18"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground, FallbackValue={StaticResource Cad.Muted}, TargetNullValue={StaticResource Cad.Muted}}" />
          </Button>
          <Button x:Name="BtnRefreshCatalog"
                  Style="{StaticResource ToolbarRefreshButton}"
                  ToolTip="刷新命令表"
                  Click="RefreshCatalog_Click">
            <ContentControl Style="{StaticResource ToolbarRefreshIcon}"
                            Width="18"
                            Height="18"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground, FallbackValue={StaticResource Cad.Muted}, TargetNullValue={StaticResource Cad.Muted}}" />
          </Button>
        </StackPanel>

        <Border Grid.Row="2"
                Background="{StaticResource Cad.RowAlt}"
                BorderBrush="{StaticResource Cad.StatusLine}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText"
                       Grid.Column="0"
                       Style="{StaticResource CadWidePageStatusText}"
                       Text="" />
            <TextBlock x:Name="SaveTargetText"
                       Grid.Column="1"
                       Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"
                       Foreground="{StaticResource Cad.Muted}"
                       FontSize="12"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       TextAlignment="Right"
                       ToolTipService.ShowDuration="30000" />
          </Grid>
        </Border>
  </Grid>
</Window>
