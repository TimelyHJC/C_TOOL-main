<UserControl x:Class="C_toolsPlugin.DimStyleBatchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:C_toolsPlugin"
             Background="#16191F"
             Foreground="#E8EAED"
             FontFamily="Microsoft YaHei UI, Segoe UI"
             FontSize="12">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/C_toolsShared;component/Themes/CadTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>

    <SolidColorBrush x:Key="Cad.Panel" Color="#262C38" />
    <SolidColorBrush x:Key="Cad.Border" Color="#21262D" />
    <SolidColorBrush x:Key="Cad.Muted" Color="#8B949E" />
    <SolidColorBrush x:Key="Cad.Accent" Color="#58A6FF" />
    <SolidColorBrush x:Key="Cad.InputBg" Color="#262C38" />
    <SolidColorBrush x:Key="Cad.GridBg" Color="#16191F" />
    <SolidColorBrush x:Key="Cad.GridHeaderBg" Color="#1B1F28" />
    <SolidColorBrush x:Key="Cad.GridRow" Color="#12141A" />
    <SolidColorBrush x:Key="Cad.GridRowAlt" Color="#12141A" />
    <SolidColorBrush x:Key="Cad.GridRowHover" Color="#222731" />
    <SolidColorBrush x:Key="Cad.ScrollTrack" Color="#10151C" />
    <SolidColorBrush x:Key="Cad.ScrollThumb" Color="#3D4756" />
    <SolidColorBrush x:Key="Cad.ScrollThumbHover" Color="#4E5A6A" />
    <SolidColorBrush x:Key="Cad.ButtonPrimary" Color="#1E77B4" />
    <SolidColorBrush x:Key="Cad.ToolbarBg" Color="#323B4A" />
    <SolidColorBrush x:Key="Cad.StatusLine" Color="#30363D" />

    <Style TargetType="TextBox">
      <Setter Property="Background" Value="{StaticResource Cad.InputBg}" />
      <Setter Property="Foreground" Value="#E6E8EA" />
      <Setter Property="BorderBrush" Value="{StaticResource Cad.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CaretBrush" Value="#E6E8EA" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="#E6E8EA" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <DataTemplate x:Key="DimTplValueText">
      <TextBox Text="{Binding TextValue, UpdateSourceTrigger=PropertyChanged}" />
    </DataTemplate>
    <DataTemplate x:Key="DimTplValueArrow">
      <Border Height="32"
              Background="{StaticResource Cad.InputBg}"
              BorderBrush="{StaticResource Cad.Border}"
              BorderThickness="1"
              CornerRadius="4">
        <ComboBox Style="{StaticResource CadToolbarComboBox}"
                  VerticalAlignment="Stretch"
                  ItemsSource="{Binding ArrowBlocks, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  SelectedValue="{Binding ArrowBlockName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  SelectedValuePath="BlockName"
                  ToolTip="DIMBLK：默认闭合箭头，或从当前图纸块表中选择">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Display}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </Border>
    </DataTemplate>
    <DataTemplate x:Key="DimTplValueCheck">
      <CheckBox Content=""
                ToolTip="DIMFXLENON：启用固定长度界线"
                IsChecked="{Binding BoolValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center"
                HorizontalAlignment="Left" />
    </DataTemplate>
    <DataTemplate x:Key="DimTplValueTextStyle">
      <Border Height="32"
              Background="{StaticResource Cad.InputBg}"
              BorderBrush="{StaticResource Cad.Border}"
              BorderThickness="1"
              CornerRadius="4">
        <ComboBox Style="{StaticResource CadToolbarComboBox}"
                  VerticalAlignment="Stretch"
                  ItemsSource="{Binding TextStyles, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  SelectedItem="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  ToolTip="DIMTXSTY：从当前图纸文字样式表选择" />
      </Border>
    </DataTemplate>

    <Style x:Key="DimStyleValueRowStyle" TargetType="ContentControl">
      <Setter Property="ContentTemplate" Value="{StaticResource DimTplValueText}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding RowKey}" Value="arrow">
          <Setter Property="ContentTemplate" Value="{StaticResource DimTplValueArrow}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding RowKey}" Value="dimtxsty">
          <Setter Property="ContentTemplate" Value="{StaticResource DimTplValueTextStyle}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding RowKey}" Value="dimfxlenon">
          <Setter Property="ContentTemplate" Value="{StaticResource DimTplValueCheck}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>
    </ResourceDictionary>
  </UserControl.Resources>
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Padding="16,0,16,12">
    <StackPanel>
      <Grid Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" MinWidth="140" />
          <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   VerticalAlignment="Center"
                   Margin="0,0,16,0"
                   Foreground="{StaticResource Cad.Muted}"
                   Text="分组" />
        <Border Grid.Column="1"
                Height="32"
                Background="{StaticResource Cad.InputBg}"
                BorderBrush="{StaticResource Cad.Border}"
                BorderThickness="1"
                CornerRadius="4">
          <ComboBox x:Name="DimGroupCombo"
                    Style="{StaticResource CadToolbarComboBox}"
                    VerticalAlignment="Stretch"
                    SelectionChanged="DimGroupCombo_SelectionChanged">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding DisplayLabel}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Border>
      </Grid>

      <ItemsControl ItemsSource="{Binding FieldRows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type local:DimStyleFieldRow}">
            <Grid Margin="0,0,0,14">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="140" />
                <ColumnDefinition Width="280" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0">
                <TextBlock Text="{Binding Label}"
                           Foreground="{StaticResource Cad.Muted}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding Hint}"
                           FontSize="11"
                           Foreground="{StaticResource Cad.Muted}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
              </StackPanel>
              <ContentControl Grid.Column="1"
                              VerticalAlignment="Center"
                              Content="{Binding}"
                              Style="{StaticResource DimStyleValueRowStyle}" />
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
