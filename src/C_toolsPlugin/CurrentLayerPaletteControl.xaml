<UserControl x:Class="C_toolsPlugin.CurrentLayerPaletteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#2E3745"
             Foreground="#E8EAED"
             FontFamily="Microsoft YaHei UI, Segoe UI"
             FontSize="12"
             MinWidth="300"
             MinHeight="260">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/C_toolsShared;component/Themes/CadTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <Style x:Key="PaletteFieldCaption" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#AEB8C7" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,10,0" />
      </Style>

      <Style x:Key="PaletteFieldValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
      </Style>

      <Style x:Key="PaletteSectionCaption" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#F0F3F8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,12,0,8" />
      </Style>

      <Style x:Key="PaletteOptionButton" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="116" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Background" Value="#333D4C" />
        <Setter Property="Foreground" Value="#F0F3F8" />
        <Setter Property="BorderBrush" Value="#465263" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="Bd"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="2"
                      Padding="{TemplateBinding Padding}"
                      SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="Tag" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#47617E" />
                  <Setter TargetName="Bd" Property="BorderBrush" Value="#6EA8E5" />
                  <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#3F4B5D" />
                  <Setter TargetName="Bd" Property="BorderBrush" Value="#6EA8E5" />
                </Trigger>
                <MultiTrigger>
                  <MultiTrigger.Conditions>
                    <Condition Property="Tag" Value="True" />
                    <Condition Property="IsMouseOver" Value="True" />
                  </MultiTrigger.Conditions>
                  <Setter TargetName="Bd" Property="Background" Value="#537092" />
                </MultiTrigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#252D39" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Opacity" Value="0.45" />
                  <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="PaletteTabButton" TargetType="RadioButton" BasedOn="{StaticResource CadRadioTabButton}">
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="BorderThickness" Value="0,0,0,0" />
      </Style>

      <Style x:Key="PaletteLayerDropDownToggle" TargetType="ToggleButton">
        <Setter Property="Height" Value="24" />
        <Setter Property="Background" Value="#333D4C" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#465263" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ToggleButton">
              <Border x:Name="Bd"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="2"
                      SnapsToDevicePixels="True">
                <Grid>
                  <ContentPresenter Margin="8,0,24,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center" />
                  <Path Width="8"
                        Height="5"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Data="M 0,0 L 8,0 L 4,5 Z"
                        Fill="#C5CEDB"
                        IsHitTestVisible="False" />
                </Grid>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#3F4B5D" />
                  <Setter TargetName="Bd" Property="BorderBrush" Value="#6EA8E5" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="Bd" Property="BorderBrush" Value="#6EA8E5" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Opacity" Value="0.45" />
                  <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="LayerDropDownHeaderBorder" TargetType="Border">
        <Setter Property="Height" Value="28" />
        <Setter Property="Background" Value="#465163" />
        <Setter Property="BorderBrush" Value="#566275" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
      </Style>

      <Style x:Key="LayerDropDownRowBorder" TargetType="Border">
        <Setter Property="Height" Value="24" />
        <Setter Property="Background" Value="#3A4554" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="#465263" />
          </Trigger>
          <DataTrigger Binding="{Binding IsCurrent}" Value="True">
            <Setter Property="Background" Value="#149BD0" />
          </DataTrigger>
        </Style.Triggers>
      </Style>

      <Style x:Key="LayerDropDownIconButton" TargetType="Button">
        <Setter Property="Width" Value="58" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <EventSetter Event="PreviewMouseLeftButtonUp" Handler="LayerDropDownIconButton_PreviewMouseLeftButtonUp" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="Bd" Background="{TemplateBinding Background}">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#526175" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#27313F" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid Background="#2E3745"
        SnapsToDevicePixels="True">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="#27313F"
            BorderBrush="#1E2631"
            BorderThickness="0,0,0,1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Margin="8,0,0,0">
          <RadioButton x:Name="TabLayer"
                       GroupName="CurrentLayerPaletteTabs"
                       Style="{StaticResource PaletteTabButton}"
                       Content="图层"
                       IsChecked="True"
                       Checked="Tab_Checked" />
          <RadioButton x:Name="TabStyles"
                       GroupName="CurrentLayerPaletteTabs"
                       Style="{StaticResource PaletteTabButton}"
                       Content="样式"
                       Checked="Tab_Checked" />
        </StackPanel>

      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <ScrollViewer x:Name="LayerPage"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,10,12,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="68" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="28" />
              <RowDefinition Height="28" />
              <RowDefinition Height="28" />
              <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource PaletteFieldCaption}" Text="快捷键" />
            <TextBlock x:Name="ShortcutText" Grid.Row="0" Grid.Column="1" Style="{StaticResource PaletteFieldValue}" Text="-" />
            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource PaletteFieldCaption}" Text="当前图层" />
            <Grid Grid.Row="1" Grid.Column="1">
              <ToggleButton x:Name="LayerDropDownToggle"
                            Style="{StaticResource PaletteLayerDropDownToggle}"
                            IsChecked="{Binding IsOpen, ElementName=LayerDropDownPopup, Mode=TwoWay}">
                <TextBlock x:Name="LayerDropDownText"
                           Foreground="#FFFFFF"
                           FontSize="13"
                           Text="-"
                           TextTrimming="CharacterEllipsis" />
              </ToggleButton>
              <Popup x:Name="LayerDropDownPopup"
                     AllowsTransparency="True"
                     Focusable="False"
                     IsOpen="{Binding IsChecked, ElementName=LayerDropDownToggle, Mode=TwoWay}"
                     Placement="Bottom"
                     PlacementTarget="{Binding ElementName=LayerDropDownToggle}"
                     PopupAnimation="Slide"
                     StaysOpen="False">
                <Border Width="560"
                        MaxHeight="360"
                        Background="#3A4554"
                        BorderBrush="#1E2631"
                        BorderThickness="1"
                        SnapsToDevicePixels="True">
                  <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource LayerDropDownHeaderBorder}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="288" />
                          <ColumnDefinition Width="58" />
                          <ColumnDefinition Width="58" />
                          <ColumnDefinition Width="98" />
                          <ColumnDefinition Width="58" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="#FFFFFF" Text="名称" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#FFFFFF" Text="开" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#FFFFFF" Text="冻结" />
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#FFFFFF" Text="新视口冻结" />
                        <TextBlock Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#FFFFFF" Text="锁定" />
                      </Grid>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                      <ItemsControl x:Name="LayerRows">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Style="{StaticResource LayerDropDownRowBorder}"
                                    ToolTip="{Binding LayerName}"
                                    MouseLeftButtonUp="LayerDropDownRow_MouseLeftButtonUp">
                              <Grid>
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="288" />
                                  <ColumnDefinition Width="58" />
                                  <ColumnDefinition Width="58" />
                                  <ColumnDefinition Width="98" />
                                  <ColumnDefinition Width="58" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Margin="6,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="#FFFFFF"
                                           FontSize="13"
                                           Text="{Binding LayerName}"
                                           TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource LayerDropDownIconButton}"
                                        ToolTip="{Binding OnToolTip}"
                                        PreviewMouseLeftButtonDown="LayerOnDropDownButton_PreviewMouseLeftButtonDown">
                                  <Image Width="16" Height="16" Source="{Binding OnIcon}" />
                                </Button>
                                <Button Grid.Column="2"
                                        Style="{StaticResource LayerDropDownIconButton}"
                                        ToolTip="{Binding FreezeToolTip}"
                                        PreviewMouseLeftButtonDown="LayerFreezeDropDownButton_PreviewMouseLeftButtonDown">
                                  <Image Width="16" Height="16" Source="{Binding FreezeIcon}" />
                                </Button>
                                <Button Grid.Column="3"
                                        Style="{StaticResource LayerDropDownIconButton}"
                                        Width="98"
                                        ToolTip="{Binding NewViewportFreezeToolTip}"
                                        PreviewMouseLeftButtonDown="LayerNewViewportFreezeDropDownButton_PreviewMouseLeftButtonDown">
                                  <Image Width="16" Height="16" Source="{Binding NewViewportFreezeIcon}" />
                                </Button>
                                <Button Grid.Column="4"
                                        Style="{StaticResource LayerDropDownIconButton}"
                                        ToolTip="{Binding LockToolTip}"
                                        PreviewMouseLeftButtonDown="LayerLockDropDownButton_PreviewMouseLeftButtonDown">
                                  <Image Width="16" Height="16" Source="{Binding LockIcon}" />
                                </Button>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </DockPanel>
                </Border>
              </Popup>
            </Grid>
            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource PaletteFieldCaption}" Text="图纸" />
            <TextBlock x:Name="DocumentText" Grid.Row="2" Grid.Column="1" Style="{StaticResource PaletteFieldValue}" Text="-" />
            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource PaletteFieldCaption}" Text="颜色" />
            <TextBlock x:Name="ColorText" Grid.Row="3" Grid.Column="1" Style="{StaticResource PaletteFieldValue}" Text="-" />
          </Grid>

          <TextBlock Style="{StaticResource PaletteSectionCaption}" Text="图层选项" />
          <WrapPanel>
            <Button x:Name="BtnLayerOn"
                    Style="{StaticResource PaletteOptionButton}"
                    Click="LayerOn_Click">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Image x:Name="IconLayerOn" Width="16" Height="16" Margin="0,0,6,0" />
                <TextBlock Text="开关" />
              </StackPanel>
            </Button>
            <Button x:Name="BtnLayerFreeze"
                    Style="{StaticResource PaletteOptionButton}"
                    Click="LayerFreeze_Click">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Image x:Name="IconLayerFreeze" Width="16" Height="16" Margin="0,0,6,0" />
                <TextBlock Text="冻结" />
              </StackPanel>
            </Button>
            <Button x:Name="BtnViewportFreeze"
                    Style="{StaticResource PaletteOptionButton}"
                    Click="ViewportFreeze_Click">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Image x:Name="IconViewportFreeze" Width="16" Height="16" Margin="0,0,6,0" />
                <TextBlock Text="视口冻结" />
              </StackPanel>
            </Button>
            <Button x:Name="BtnLayerLock"
                    Style="{StaticResource PaletteOptionButton}"
                    Click="LayerLock_Click">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Image x:Name="IconLayerLock" Width="16" Height="16" Margin="0,0,6,0" />
                <TextBlock Text="锁定" />
              </StackPanel>
            </Button>
            <Button x:Name="BtnLayerColor"
                    Style="{StaticResource PaletteOptionButton}"
                    Click="LayerColor_Click">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Image x:Name="IconLayerColor" Width="16" Height="16" Margin="0,0,6,0" />
                <TextBlock Text="图层色" />
              </StackPanel>
            </Button>
            <Button x:Name="BtnViewportColor"
                    Style="{StaticResource PaletteOptionButton}"
                    Click="ViewportColor_Click">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Image x:Name="IconViewportColor" Width="16" Height="16" Margin="0,0,6,0" />
                <TextBlock Text="视口色" />
              </StackPanel>
            </Button>
          </WrapPanel>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="StylePage"
                    Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto">
        <Grid Margin="12,10,12,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="68" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="28" />
            <RowDefinition Height="28" />
            <RowDefinition Height="28" />
            <RowDefinition Height="28" />
            <RowDefinition Height="28" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource PaletteFieldCaption}" Text="标注" />
          <TextBlock x:Name="DimStyleText" Grid.Row="0" Grid.Column="1" Style="{StaticResource PaletteFieldValue}" Text="-" />
          <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource PaletteFieldCaption}" Text="文字" />
          <TextBlock x:Name="TextStyleText" Grid.Row="1" Grid.Column="1" Style="{StaticResource PaletteFieldValue}" Text="-" />
          <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource PaletteFieldCaption}" Text="引线" />
          <TextBlock x:Name="MLeaderStyleText" Grid.Row="2" Grid.Column="1" Style="{StaticResource PaletteFieldValue}" Text="-" />
          <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource PaletteFieldCaption}" Text="线型" />
          <TextBlock x:Name="LinetypeText" Grid.Row="3" Grid.Column="1" Style="{StaticResource PaletteFieldValue}" Text="-" />
          <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource PaletteFieldCaption}" Text="线型比例" />
          <TextBlock x:Name="LinetypeScaleText" Grid.Row="4" Grid.Column="1" Style="{StaticResource PaletteFieldValue}" Text="-" />
          <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource PaletteFieldCaption}" Text="线宽" />
          <TextBlock x:Name="LineweightText" Grid.Row="5" Grid.Column="1" Style="{StaticResource PaletteFieldValue}" Text="-" />
        </Grid>
      </ScrollViewer>
    </Grid>

    <Border Grid.Row="2"
            Background="#27313F"
            BorderBrush="#1E2631"
            BorderThickness="0,1,0,0"
            Padding="10,8">
      <TextBlock x:Name="StatusText"
                 Foreground="#B8C5D6"
                 FontSize="12"
                 TextWrapping="Wrap"
                 Text="正在读取当前图层状态..." />
    </Border>
  </Grid>
</UserControl>
